# Plan 9 Task 1 Rev. 2.1: Staging Caddyfile -- Let's Encrypt STAGING-CA.
# Use during first-deploy validation to avoid burning production
# rate-limit (50 certs/domain/week). Mount via docker-compose-override:
#   docker compose --env-file .env.production \
#     -f docker-compose.yml -f docker-compose.prod.yml \
#     -f docker-compose.prod.staging-caddy.yml \
#     up -d caddy
# Browser-warnings during staging-mode are EXPECTED. Switch to
# caddy/Caddyfile (production) once DNS + reachability verified.
#
# HSTS max-age=0: staging-cert is untrusted; HSTS-pinning would break
# browsers when switching back to production. Hard-set to 0.
{
	email {$ACME_EMAIL}
	# auto_https is on by default in Caddy v2 (literal `auto_https on` not accepted).
	acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

{$DOMAIN} {
	log {
		output stdout
		format console
	}

	# Same rules as production -- only acme_ca differs and HSTS is disabled.
	header {
		Strict-Transport-Security "max-age=0"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), camera=(), microphone=(), interest-cohort=()"
		-Server
	}

	# encode applies to ALL responses regardless of file-order -- Caddy v2 uses
	# directive-order, not file-order. Placing here for visual flow only.
	encode gzip zstd

	@static path /static/*
	header @static {
		Cache-Control "public, max-age=3600"
	}

	# SSE-matcher tightened to full UUID-shape (defense-in-depth): rejects
	# non-UUID-shaped paths from accidentally entering the unbuffered code-path.
	@sse path_regexp ^/jobs/[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}/events$
	reverse_proxy @sse api:3000 {
		flush_interval -1
		# X-Forwarded-Proto/Host are set by Caddy v2 reverse_proxy by default --
		# no explicit header_up needed.
	}

	@tus path /uploads/*
	reverse_proxy @tus tusd:1080 {
		header_up X-Tusd-Shared-Secret {$TUSD_SHARED_SECRET}
		# X-Forwarded-Proto/Host are set by Caddy v2 reverse_proxy by default.
		transport http {
			versions 1.1
		}
	}

	# X-Forwarded-Proto/Host are set by Caddy v2 reverse_proxy by default.
	reverse_proxy api:3000
}
