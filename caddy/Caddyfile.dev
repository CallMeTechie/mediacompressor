# Plan 9 Task 1 Rev. 2.1: Caddyfile.dev -- local staging without Let's Encrypt.
# Use cases:
# - Test the Caddy config locally before production-deploy.
# - Run E2E (Task 6) against the production-stack on `localhost`.
#
# Uses Caddy's internal CA (self-signed) -- browser will warn, curl needs
# --insecure. Behaves identically to production for routing/headers/SSE/tusd
# so that Rev. 2.1 WC-prod-16 holds: SSE + tusd + headers tested in dev MUST
# match production.
{
	# `auto_https disable_redirects` keeps Caddy from auto-issuing real certs
	# AND from forcing 80->443 redirects. Combined with `tls internal` (issues
	# local self-signed certs from Caddy's internal CA), this gives a fully
	# offline-capable HTTPS-on-localhost setup for E2E tests.
	auto_https disable_redirects
	local_certs
}

localhost {
	# max-age=0: HSTS disabled -- self-signed certs MUST NOT trust-pin.
	# Defensive even when running behind a real mkcert-rooted cert in dev.
	tls internal

	log {
		output stdout
		format console
	}

	header {
		Strict-Transport-Security "max-age=0"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), camera=(), microphone=(), interest-cohort=()"
		-Server
	}

	# encode applies to ALL responses regardless of file-order -- Caddy v2 uses
	# directive-order, not file-order. Placing here for visual flow only.
	encode gzip zstd

	@static path /static/*
	header @static {
		Cache-Control "public, max-age=3600"
	}

	# SSE-matcher tightened to full UUID-shape (defense-in-depth): rejects
	# non-UUID-shaped paths from accidentally entering the unbuffered code-path.
	@sse path_regexp ^/jobs/[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}/events$
	reverse_proxy @sse api:3000 {
		flush_interval -1
		# X-Forwarded-Proto/Host are set by Caddy v2 reverse_proxy by default --
		# no explicit header_up needed.
	}

	@tus path /uploads/*
	reverse_proxy @tus tusd:1080 {
		header_up X-Tusd-Shared-Secret {$TUSD_SHARED_SECRET}
		# X-Forwarded-Proto/Host are set by Caddy v2 reverse_proxy by default.
		transport http {
			versions 1.1
		}
	}

	# X-Forwarded-Proto/Host are set by Caddy v2 reverse_proxy by default.
	reverse_proxy api:3000
}
