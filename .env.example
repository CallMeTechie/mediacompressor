# Compose-/App-Konfiguration; lokal als ".env" kopieren

# Postgres
POSTGRES_USER=mediacompressor
POSTGRES_PASSWORD=changeme-dev
POSTGRES_DB=mediacompressor

# Database-URL für Prisma (in der API) und für migrate-Service
DATABASE_URL=postgresql://mediacompressor:changeme-dev@postgres:5432/mediacompressor?schema=public

# Plan 4: API + Worker Secrets (DEV-ONLY placeholders — replace in production!)
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-32+-char-random-string-PROD-WILL-FAIL-WITHOUT-THIS-1234567890
CSRF_SECRET=change-me-to-a-32+-char-random-string-PROD-WILL-FAIL-WITHOUT-THIS-1234567890
API_KEY_PEPPER=change-me-to-a-32+-char-random-string-PROD-WILL-FAIL-WITHOUT-THIS-12345678

# Worker concurrency per container (default 2 → 1 Video + 1 Image parallel).
# WORKER_CONCURRENCY=2
