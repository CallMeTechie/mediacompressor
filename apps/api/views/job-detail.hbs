<header class="page-header">
  <h1>{{job.inputFilename}}</h1>
  <nav class="page-nav">
    <a href="/jobs">{{t 'detail_nav_all_jobs' ns='jobs'}}</a>
    <a href="/">{{t 'detail_nav_dashboard' ns='jobs'}}</a>
  </nav>
</header>

<section class="job-detail">
  {{> flash}}
  <div id="job-detail-sse-target"
       data-sse-target
       data-sse-url="/api/v1/jobs/{{job.id}}/events"
       data-fragment-url="/jobs/{{job.id}}?fragment=1"
       hx-ext="sse"
       sse-connect="/api/v1/jobs/{{job.id}}/events"
       hx-get="/jobs/{{job.id}}?fragment=1"
       hx-trigger="sse:status, sse:progress, sse:snapshot"
       hx-swap="innerHTML">
    {{> job-detail-status job}}
  </div>
  <p>{{t 'detail_label_kind_profile' ns='jobs' kind=(tKind job.kind) profile=(tProfile job.profile)}}</p>
  {{#if job.inputBytes}}<p>{{t 'detail_label_input_size' ns='jobs' bytes=job.inputBytes}}</p>{{/if}}

  {{#if canCancel}}
  <form method="POST" action="/jobs/{{job.id}}/cancel">
    {{{_csrfField}}}
    <button type="submit" class="btn">{{t 'detail_button_cancel' ns='jobs'}}</button>
  </form>
  {{/if}}

  {{#if canDownload}}
  <a class="btn" href="/api/v1/jobs/{{job.id}}/download">{{t 'detail_button_download' ns='jobs'}}</a>
  {{/if}}
</section>

<script src="/static/js/job-detail-watchdog.js" defer></script>
