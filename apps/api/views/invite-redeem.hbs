<h1>{{title}}</h1>
{{#if consumed}}
  <p class="flash flash-error">{{t 'invite_redeem_state_consumed' ns='auth'}}</p>
{{else if expired}}
  <p class="flash flash-error">{{t 'invite_redeem_state_expired' ns='auth'}}</p>
{{else}}
  {{> flash}}
  <form method="POST" action="/invites/{{token}}" class="invite-form">
    {{> csrf}}
    <div class="form-field">
      <label for="email">{{t 'invite_redeem_label_email' ns='auth'}}</label>
      <input id="email" type="email" name="email" value="{{email}}" required autofocus>
    </div>
    <div class="form-field">
      <label for="password">{{t 'invite_redeem_label_password' ns='auth'}}</label>
      <input id="password" name="password" type="password" minlength="12" required>
    </div>
    <button type="submit" class="btn">{{t 'invite_redeem_button_submit' ns='auth'}}</button>
  </form>
{{/if}}
