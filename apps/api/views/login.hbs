<h1>{{t 'login_title' ns='auth'}}</h1>
{{> flash}}
<form method="POST" action="/login" class="login-form">
  {{> csrf}}
  <div class="form-field">
    <label for="email">{{t 'login_label_email' ns='auth'}}</label>
    <input id="email" type="email" name="email" value="{{email}}" required autofocus>
  </div>
  <div class="form-field">
    <label for="password">{{t 'login_label_password' ns='auth'}}</label>
    <input id="password" name="password" type="password" required>
  </div>
  <button type="submit" class="btn">{{t 'login_button_submit' ns='auth'}}</button>
</form>
<p class="muted">{{t 'login_invite_hint' ns='auth'}}</p>
