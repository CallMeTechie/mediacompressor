<header class="page-header">
  <h1>{{t 'page_title_api_keys' ns='profile'}}</h1>
  <nav class="page-nav">
    <a href="/profile">{{t 'nav_profile' ns='profile'}}</a>
    <a href="/profile/api-keys/new" class="btn">{{t 'button_apikey_create' ns='profile'}}</a>
  </nav>
</header>

{{> flash}}

{{#if keys.length}}
<table class="profile-table">
  <thead><tr><th>{{t 'label_apikey_name' ns='profile'}}</th><th>{{t 'label_apikey_prefix' ns='profile'}}</th><th>{{t 'label_apikey_scopes' ns='profile'}}</th><th>{{t 'label_apikey_created' ns='profile'}}</th><th>{{t 'label_apikey_last_used' ns='profile'}}</th><th></th></tr></thead>
  <tbody>
    {{#each keys}}
      <tr>
        <td>{{name}}</td>
        <td><code>{{keyPrefix}}&hellip;</code></td>
        <td><code>{{#each scopes}}{{this}} {{/each}}</code></td>
        <td><time datetime="{{createdAt}}">{{formatDate createdAt}}</time></td>
        <td>
          {{#if lastUsedAt}}<time datetime="{{lastUsedAt}}">{{formatDate lastUsedAt}}</time>{{else}}<span class="muted">{{t 'label_apikey_never_used' ns='profile'}}</span>{{/if}}
        </td>
        <td>
          <form method="POST" action="/profile/api-keys/{{id}}/revoke" class="inline-form">
            {{!-- Inside {{#each keys}} the partial sees the row as its own
                 context. Pass @root so {{> csrf}} resolves _csrfField
                 against the parent view-context (Plan-8d Task 7 regression
                 fix; same pattern as admin-invites-list.hbs). MUST stay
                 `@root` after the Plan-8e i18n migration — see WC-i18n-5
                 PFLICHT in api-keys-list-page.test.ts. --}}
            {{> csrf @root}}
            <button type="submit" class="btn-link">{{t 'button_apikey_revoke' ns='profile'}}</button>
          </form>
        </td>
      </tr>
    {{/each}}
  </tbody>
</table>
{{else}}
<p class="muted">{{t 'apikey_empty_list' ns='profile'}} <a href="/profile/api-keys/new">{{t 'apikey_empty_link' ns='profile'}}</a>.</p>
{{/if}}
