<header class="page-header">
  <h1>Upload a file</h1>
  <nav class="page-nav"><a href="/">Dashboard</a></nav>
</header>

<noscript>
  <style>#upload-form { display: none; }</style>
  <p class="flash flash-error">
    This upload requires JavaScript (resumable uploads via <code>tus.min.js</code>).
    With JavaScript disabled, please use the JSON API directly &mdash; see
    <a href="/api/v1/docs">API documentation</a>.
  </p>
</noscript>

<form id="upload-form" class="upload-form">
  {{> csrf}}
  <div class="form-field">
    <label for="file">File</label>
    <input id="file" type="file" name="file" required>
  </div>
  <div class="form-field">
    <fieldset>
      <legend>Kind</legend>
      <label><input type="radio" name="kind" value="image" checked> Image</label>
      <label><input type="radio" name="kind" value="video"> Video</label>
    </fieldset>
  </div>
  <div class="form-field">
    <label for="profile">Profile</label>
    <select id="profile" name="profile">
      {{#each profiles}}<option value="{{this}}">{{this}}</option>{{/each}}
    </select>
  </div>
  <button type="submit" class="btn">Upload</button>
</form>

<div id="upload-progress" hidden>
  <p>Uploading&hellip; <span id="upload-percent">0</span>%</p>
  <progress id="upload-bar" value="0" max="100"></progress>
</div>

<script src="/static/vendor/tus.min.js" defer></script>
<script src="/static/js/upload-wizard.js" defer></script>
