<header class="page-header">
  <h1>{{t 'page_title' ns='dashboard'}}</h1>
  <nav class="page-nav">
    <a href="/jobs">{{t 'nav_link_all_jobs' ns='dashboard'}}</a>
    <a href="/upload">{{t 'nav_link_upload' ns='dashboard'}}</a>
  </nav>
</header>

<section class="dashboard-summary">
  <p>{{t 'welcome_heading' ns='dashboard' email=user.email}}</p>
  <p class="muted">{{t 'summary_in_flight' ns='dashboard' count=inFlightCount}} <a href="/jobs">{{t 'link_view_all_jobs' ns='dashboard'}}</a></p>
</section>

<section class="recent-jobs">
  <h2>{{t 'section_recent_jobs' ns='dashboard'}}</h2>
  {{#if recentJobs.length}}
  <ul class="job-list">
    {{#each recentJobs}}
      <li>
        <a href="/jobs/{{id}}">{{inputFilename}}</a>
        {{> job-status-badge}}
        <span class="muted">{{kind}} · {{profile}}</span>
      </li>
    {{/each}}
  </ul>
  {{else}}
  <p class="muted">{{t 'empty_no_jobs' ns='dashboard'}} <a href="/upload">{{t 'button_new_upload' ns='dashboard'}}</a>.</p>
  {{/if}}
</section>
