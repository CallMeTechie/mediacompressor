<header class="page-header">
  <h1>{{t 'page_title_stats'}}</h1>
  <nav class="page-nav">
    <a href="/admin">{{t 'nav_dashboard'}}</a>
    <a href="/admin/users">{{t 'nav_users'}}</a>
    <a href="/admin/invites">{{t 'nav_invites'}}</a>
  </nav>
</header>

<section class="stats-section">
  <h2>{{t 'stats_section_users'}}</h2>
  <dl>
    <dt>{{t 'stats_users_total'}}</dt><dd>{{stats.users.total}}</dd>
  </dl>
</section>

<section class="stats-section">
  <h2>{{t 'stats_section_jobs'}}</h2>
  {{#if stats.jobRows.length}}
    <table class="admin-table">
      <thead>
        <tr>
          <th>{{t 'stats_jobs_table_status'}}</th>
          <th>{{t 'stats_jobs_table_count'}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each stats.jobRows}}
          <tr>
            <td>{{t labelKey status=status}}</td>
            <td>{{count}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p class="muted">{{t 'stats_jobs_empty'}}</p>
  {{/if}}
</section>

<section class="stats-section">
  <h2>{{t 'stats_section_storage'}}</h2>
  <dl>
    <dt>{{t 'stats_storage_used'}}</dt><dd>{{stats.storage.usedBytes}}</dd>
    {{#if stats.storage.diskFree}}
      <dt>{{t 'stats_storage_disk_available'}}</dt><dd>{{stats.storage.diskFree.available}}</dd>
      <dt>{{t 'stats_storage_disk_total'}}</dt><dd>{{stats.storage.diskFree.total}}</dd>
    {{else}}
      <dt><em>{{t 'stats_storage_disk_unavailable'}}</em></dt><dd>&mdash;</dd>
    {{/if}}
  </dl>
</section>

<section class="stats-section">
  <h2>{{t 'stats_section_queue'}}</h2>
  <dl>
    <dt>{{t 'stats_queue_waiting'}}</dt><dd>{{stats.queue.compressionWaiting}}</dd>
    <dt>{{t 'stats_queue_active'}}</dt><dd>{{stats.queue.compressionActive}}</dd>
  </dl>
</section>
