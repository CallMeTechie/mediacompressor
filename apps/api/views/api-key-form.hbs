<header class="page-header">
  <h1>{{t 'page_title_api_key_create' ns='profile'}}</h1>
  <nav class="page-nav"><a href="/profile/api-keys">{{t 'nav_cancel' ns='profile'}}</a></nav>
</header>

{{> flash}}

<form method="POST" action="/profile/api-keys" class="api-key-form">
  {{> csrf}}
  <div class="form-field">
    <label for="name">{{t 'label_apikey_name' ns='profile'}}</label>
    <input id="name" name="name" type="text" required maxlength="64" autofocus>
  </div>
  <p class="muted">{{t 'apikey_form_hint_scopes' ns='profile'}} <code>jobs:read jobs:write</code></p>
  <button type="submit" class="btn">{{t 'apikey_form_button_submit' ns='profile'}}</button>
</form>
