<header class="page-header">
  <h1>Your jobs</h1>
  <nav class="page-nav">
    <a href="/">Dashboard</a>
    <a href="/upload">Upload</a>
  </nav>
</header>

<section class="filter-bar">
  <a href="/jobs" class="filter-pill {{#unless statusFilter}}active{{/unless}}">All</a>
  {{#each statusOptions}}
    <a href="/jobs?status={{value}}" class="filter-pill {{#if active}}active{{/if}}">{{value}}</a>
  {{/each}}
</section>

<table class="job-table">
  <thead><tr><th>File</th><th>Status</th><th>Profile</th><th>Created</th></tr></thead>
  {{> job-list-rows}}
</table>

{{#if nextCursor}}
  <a class="btn" href="/jobs?cursor={{nextCursor}}{{#if statusFilter}}&status={{statusFilter}}{{/if}}">Load more</a>
{{/if}}
