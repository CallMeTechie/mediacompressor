    "handlebars": "~4.7.8",
    "htmx-ext-sse": "~2.2.0",
    "htmx.org": "~2.0.3",
    "i18next": "~23.15.0",
    "i18next-fs-backend": "~2.6.0",
    "ioredis": "~5.4.1",
    "tus-js-client": "~4.1.0",
    "zod": "~3.23.8"
  },
  "devDependencies": {
    "@mediacompressor/test-helpers": "workspace:*",
    "@playwright/test": "~1.48.0",
    "@types/node": "~22.7.0",
    "jsdom": "~25.0.1",
    "tsx": "~4.19.2"
  }
