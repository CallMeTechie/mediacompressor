{
  "name": "@mediacompressor/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:snapshot:update": "UPDATE_SNAPSHOT=1 vitest run snapshot",
    "test:e2e": "playwright test --config=test-e2e/playwright.config.ts",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@fastify/cookie": "~11.0.1",
    "@fastify/cors": "~10.0.1",
    "@fastify/csrf-protection": "~7.0.0",
    "@fastify/formbody": "~8.0.0",
    "@fastify/helmet": "~13.0.0",
    "@fastify/http-proxy": "~10.0.0",
    "@fastify/static": "~8.0.0",
    "@fastify/swagger": "~9.7.0",
    "@fastify/swagger-ui": "~5.2.0",
    "@fastify/view": "~11.1.1",
    "@mediacompressor/audit": "workspace:*",
    "@mediacompressor/auth": "workspace:*",
    "@mediacompressor/cleanup": "workspace:*",
    "@mediacompressor/compression": "workspace:*",
    "@mediacompressor/db": "workspace:*",
    "@mediacompressor/shared": "workspace:*",
    "@mediacompressor/storage": "workspace:^",
    "bullmq": "~5.34.0",
    "fastify": "~5.1.0",
    "fastify-plugin": "~5.1.0",
    "fastify-type-provider-zod": "~4.0.2",
