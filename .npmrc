# Plan 2 Task 4-bis: zwingt sharp dazu, gegen system-libvips zu builden.
# Ohne diese Variable liefert pnpm install einen sharp-prebuild ohne HEVC-Encoder
# (Patent-Lizenz), und HEIC-Encoding scheitert mit „Unsupported compression".
#
# Mit dieser Variable sucht sharp die system-libvips (libvips-dev) und linkt
# gegen die system-libheif, die libheif-plugin-x265 lädt.
#
# Pflicht-System-Deps (apt): libvips-dev libheif-dev libheif-plugin-x265
# Pflicht-Build-Deps (npm): node-addon-api node-gyp
SHARP_FORCE_GLOBAL_LIBVIPS=true
engine-strict=true
