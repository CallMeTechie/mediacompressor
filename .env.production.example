# Plan 9 Task 3: Production environment template.
# Copy to `.env.production` and fill ALL values BEFORE first deploy.
# After fill: chmod 600 .env.production && chown root:root .env.production
# DO NOT commit .env.production to git (.gitignore guards this).

# === Public Identity ===
DOMAIN=mediacompressor.example.com
ACME_EMAIL=ops@example.com

# === Postgres ===
POSTGRES_USER=mediacompressor
# 32+ chars, generated via: openssl rand -base64 32
POSTGRES_PASSWORD=__GENERATE_VIA_OPENSSL_RAND_BASE64_32__
POSTGRES_DB=mediacompressor

# Database-URL (matches Postgres credentials above)
DATABASE_URL=postgresql://mediacompressor:__SAME_PW_AS_POSTGRES_PASSWORD__@postgres:5432/mediacompressor?schema=public

# === API Secrets — generate EACH separately via openssl rand -hex 32 ===
SESSION_SECRET=__GENERATE_VIA_OPENSSL_RAND_HEX_32__
CSRF_SECRET=__GENERATE_VIA_OPENSSL_RAND_HEX_32__
API_KEY_PEPPER=__GENERATE_VIA_OPENSSL_RAND_HEX_32__

# === tusd ===
TUSD_SHARED_SECRET=__GENERATE_VIA_OPENSSL_RAND_HEX_32__

# === Operational ===
MIN_FREE_BYTES_RESERVE=5368709120
ENABLE_LEGACY_JOB_STUB=false
WORKER_CONCURRENCY=2
