// MediaCompressor — Datenbankschema
// Spec Sektion 4

generator client {
  provider        = "prisma-client-js"
  output          = "./generated/client"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  disabled
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique @db.Citext
  passwordHash    String
  role            UserRole   @default(user)
  status          UserStatus @default(active)
  createdAt       DateTime   @default(now()) @db.Timestamptz(6)
  storageQuota    BigInt     @default(21474836480) // 20 GB
  parallelQuota   Int        @default(3)           @db.SmallInt
  hourlyQuota     Int        @default(30)          @db.SmallInt
  invitedById     String?    @db.Uuid
  invitedBy       User?      @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedUsers    User[]     @relation("InvitedBy")

  invitesIssued   Invite[]   @relation("InviteIssuer")
  invitesConsumed Invite[]   @relation("InviteConsumer")
  sessions        Session[]
  apiKeys         ApiKey[]
  jobs            Job[]
  auditEvents     AuditEvent[] @relation("AuditEventActor")

  @@index([email])
}

model Invite {
  id            String    @id @default(uuid()) @db.Uuid
  token         String    @unique
  email         String?   @db.Citext
  createdById   String    @db.Uuid
  createdBy     User      @relation("InviteIssuer", fields: [createdById], references: [id])
  expiresAt     DateTime  @db.Timestamptz(6)
  consumedAt    DateTime? @db.Timestamptz(6)
  consumedById  String?   @db.Uuid
  consumedBy    User?     @relation("InviteConsumer", fields: [consumedById], references: [id])

  @@index([expiresAt])
}

model Session {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String   @unique
  userAgent   String
  ip          String   @db.Inet
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  lastUsedAt  DateTime @default(now()) @db.Timestamptz(6)
  expiresAt   DateTime @db.Timestamptz(6)

  @@index([userId])
  @@index([expiresAt])
}

model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String    @unique // HMAC-SHA-256(API_KEY_PEPPER, key) in Hex (Spec Sektion 7, C3-Rev2)
  keyPrefix   String    @db.VarChar(8)
  scopes      String[]
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  lastUsedAt  DateTime? @db.Timestamptz(6)
  revokedAt   DateTime? @db.Timestamptz(6)

  @@index([userId])
  @@index([revokedAt])
}

enum JobStatus {
  pending
  uploading
  queued
  processing
  succeeded
  failed
  canceled
  expired
}

enum JobKind {
  image
  video
}

enum UsageEventType {
  job_submitted
  bytes_in
  bytes_out
  job_failed
}

model Job {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploadId          String    @unique
  status            JobStatus
  kind              JobKind
  profile           String
  overrides         Json
  inputFilename     String
  reservedBytes     BigInt    @default(0)
  inputBytes        BigInt?
  inputMime         String?
  inputStorageKey   String?
  outputBytes       BigInt?
  outputMime        String?
  outputFormat      String?
  outputStorageKey  String?
  metadata          Json?
  errorCode         String?
  errorMessage      String?
  progress          Int       @default(0) @db.SmallInt
  attempts          Int       @default(0) @db.SmallInt
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  startedAt         DateTime? @db.Timestamptz(6)
  finishedAt        DateTime? @db.Timestamptz(6)
  expiresAt         DateTime? @db.Timestamptz(6)

  // UC1-Fix: Orphan-Schutz bei tusd-Crash zwischen Pre-Create und Post-Finish.
  uploadExpiresAt          DateTime? @db.Timestamptz(6)

  // UC12-Fix: Pre-Create-Hook-Retry-Idempotency. Deterministischer SHA-256-Key
  // aus (authUserId || metadata || size). Unique-Index sorgt für DB-seitige
  // Doppelreservation-Defense (race-safe).
  precreateIdempotencyKey  String?   @unique

  usageEvents       UsageEvent[]

  @@index([userId, status])
  @@index([status, expiresAt])
  @@index([userId, createdAt(sort: Desc)])
}

model UsageEvent {
  id          BigInt        @id @default(autoincrement())
  userId      String        @db.Uuid
  jobId       String?       @db.Uuid
  job         Job?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  type        UsageEventType
  value       BigInt
  occurredAt  DateTime      @default(now()) @db.Timestamptz(6)

  @@index([userId, occurredAt(sort: Desc)])
}

/// Singleton-Tabelle für API_KEY_PEPPER-Boot-Self-Check (Spec C3-Rev3).
/// `id = 1` ist die einzige zulässige Zeile.
model PepperCanary {
  id            Int      @id @default(1)
  expectedHmac  String
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  @@map("PepperCanary")
}

model AuditEvent {
  id           String   @id @default(uuid()) @db.Uuid
  actorUserId  String   @db.Uuid
  actor        User     @relation("AuditEventActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  action       String   @db.VarChar(64)
  targetType   String   @db.VarChar(32)
  targetId     String   @db.Uuid
  payload      Json?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)

  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([targetType, targetId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}
