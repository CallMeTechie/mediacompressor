// MediaCompressor — Datenbankschema
// Spec Sektion 4

generator client {
  provider        = "prisma-client-js"
  output          = "./generated/client"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  disabled
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique @db.Citext
  passwordHash    String
  role            UserRole   @default(user)
  status          UserStatus @default(active)
  createdAt       DateTime   @default(now()) @db.Timestamptz(6)
  storageQuota    BigInt     @default(21474836480) // 20 GB
  parallelQuota   Int        @default(3)           @db.SmallInt
  hourlyQuota     Int        @default(30)          @db.SmallInt
  invitedById     String?    @db.Uuid
  invitedBy       User?      @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedUsers    User[]     @relation("InvitedBy")

  invitesIssued   Invite[]   @relation("InviteIssuer")
  invitesConsumed Invite[]   @relation("InviteConsumer")
  sessions        Session[]
  apiKeys         ApiKey[]

  @@index([email])
}

model Invite {
  id            String    @id @default(uuid()) @db.Uuid
  token         String    @unique
  email         String?   @db.Citext
  createdById   String    @db.Uuid
  createdBy     User      @relation("InviteIssuer", fields: [createdById], references: [id])
  expiresAt     DateTime  @db.Timestamptz(6)
  consumedAt    DateTime? @db.Timestamptz(6)
  consumedById  String?   @db.Uuid
  consumedBy    User?     @relation("InviteConsumer", fields: [consumedById], references: [id])

  @@index([expiresAt])
}

model Session {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String   @unique
  userAgent   String
  ip          String   @db.Inet
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  lastUsedAt  DateTime @default(now()) @db.Timestamptz(6)
  expiresAt   DateTime @db.Timestamptz(6)

  @@index([userId])
  @@index([expiresAt])
}

model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String    @unique // HMAC-SHA-256(API_KEY_PEPPER, key) in Hex (Spec Sektion 7, C3-Rev2)
  keyPrefix   String    @db.VarChar(8)
  scopes      String[]
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  lastUsedAt  DateTime? @db.Timestamptz(6)
  revokedAt   DateTime? @db.Timestamptz(6)

  @@index([userId])
  @@index([revokedAt])
}
